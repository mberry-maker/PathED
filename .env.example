# Add all of these in Vercel: Project Settings > Environment Variables
# Select Production, Preview, and Development for each

# Anthropic. Generates the PathED profile.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# MailerLite. Adds subscribers to groups.
MAILERLITE_API_KEY=your_mailerlite_api_key_here
MAILERLITE_GROUP_ID=185781574226150649
MAILERLITE_SHARE_GROUP_ID=185782178289813287

# MailerSend. Sends the transactional profile email and the lead notification.
# In MailerLite, "Transactional Emails" routes through MailerSend. Get this
# key from your MailerSend dashboard (Account > API tokens). The sender domain
# accommodatedpathways.com must be verified in MailerSend, and the from
# address contact@accommodatedpathways.com must be a verified sender on it.
MAILERSEND_API_KEY=your_mailersend_api_key_here
