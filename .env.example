# Add all of these in Vercel: Project Settings > Environment Variables.
# Select Production, Preview, and Development for each.

# Anthropic. Generates the PathED profile.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Brevo. Handles both contact upsert and the transactional email send.
# Get this from Brevo dashboard > SMTP & API > API Keys. The sender
# contact@accommodatedpathways.com must be a verified sender, and
# accommodatedpathways.com must be authenticated under Senders & IPs >
# Domains for inbox deliverability.
BREVO_API_KEY=your_brevo_api_key_here

# Brevo list IDs (numeric). Find them in Brevo > Contacts > Lists.
# BREVO_LIST_ID is the newsletter list (parent's emailOptIn checkbox).
# BREVO_SHARE_LIST_ID is the leads list Reese reviews (shareWithReese).
BREVO_LIST_ID=
BREVO_SHARE_LIST_ID=
